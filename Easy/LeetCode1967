/*
    LeetCode 1967 - Number of Strings That Appear as Substrings in Word
*/

int numOfStrings(char** patterns, int patternsSize, char* word) {

    int n = strlen(word);
    int count = 0;

    for (int j = 0; j < patternsSize; j++) {
        char *words = patterns[j];
        int m = strlen(words);

        for (int i = 0; i <= n - m; i++) {
            if (strncmp(word + i, words, m) == 0) {
                count++;
                break;
            }
        }
    }

    return count;
}
